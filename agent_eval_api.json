{
  "openapi": "3.1.0",
  "info": {
    "title": "Agent Evaluation API",
    "description": "API to fetch questions and submit agent answers for scoring.",
    "version": "0.1.0"
  },
  "paths": {
    "/files/{task_id}": {
      "get": {
        "summary": "Get Associated File by Task ID",
        "description": "Downloads the file associated with the given task_id, if one exists and is mapped.",
        "operationId": "get_task_file_files__task_id__get",
        "parameters": [
          {
            "name": "task_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Task Id"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "File content.",
            "content": {
              "application/json": {
                "schema": {

                }
              },
              "*/*": {

              }
            }
          },
          "403": {
            "description": "Access denied (e.g., path traversal attempt).",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Task ID not found, no file associated, or file missing on server.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Server error reading file.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/questions": {
      "get": {
        "summary": "Get All Filtered Questions (Full Data)",
        "description": "Returns the complete list of questions with all associated data (excluding answer/annotation) filtered based on criteria.",
        "operationId": "get_questions_questions_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "items": {
                    "additionalProperties": true,
                    "type": "object"
                  },
                  "type": "array",
                  "title": "Response Get Questions Questions Get"
                }
              }
            }
          }
        }
      }
    },
    "/random-question": {
      "get": {
        "summary": "Get One Random Question (Full Data)",
        "description": "Returns a single random question with all associated data (excluding answer/annotation) from the available filtered set.",
        "operationId": "get_random_question_random_question_get",
        "responses": {
          "200": {
            "description": "A random question with its full data.",
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": true,
                  "type": "object",
                  "title": "Response Get Random Question Random Question Get"
                }
              }
            }
          },
          "404": {
            "description": "No questions available to choose from.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/submit": {
      "post": {
        "summary": "Submit Agent Answers",
        "description": "Submit answers from an agent, calculate score, and update leaderboard on Hugging Face.",
        "operationId": "submit_answers_submit_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/Submission"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Submission successful, score calculated.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ScoreResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid input data.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Task ID not found in submission or ground truth.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Server error (e.g., failed to update dataset).",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "AnswerItem": {
        "properties": {
          "task_id": {
            "type": "string",
            "title": "Task Id"
          },
          "submitted_answer": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "integer"
              },
              {
                "type": "number"
              }
            ],
            "title": "Submitted Answer",
            "description": "The agent's answer for the task_id. Accepts str, int and float"
          }
        },
        "type": "object",
        "required": [
          "task_id",
          "submitted_answer"
        ],
        "title": "AnswerItem"
      },
      "ErrorResponse": {
        "properties": {
          "detail": {
            "type": "string",
            "title": "Detail"
          }
        },
        "type": "object",
        "required": [
          "detail"
        ],
        "title": "ErrorResponse"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "ScoreResponse": {
        "properties": {
          "username": {
            "type": "string",
            "title": "Username"
          },
          "score": {
            "type": "number",
            "title": "Score"
          },
          "correct_count": {
            "type": "integer",
            "title": "Correct Count"
          },
          "total_attempted": {
            "type": "integer",
            "title": "Total Attempted"
          },
          "message": {
            "type": "string",
            "title": "Message"
          },
          "timestamp": {
            "type": "string",
            "title": "Timestamp"
          }
        },
        "type": "object",
        "required": [
          "username",
          "score",
          "correct_count",
          "total_attempted",
          "message",
          "timestamp"
        ],
        "title": "ScoreResponse"
      },
      "Submission": {
        "properties": {
          "username": {
            "type": "string",
            "minLength": 1,
            "title": "Username",
            "description": "Hugging Face username"
          },
          "agent_code": {
            "type": "string",
            "minLength": 10,
            "title": "Agent Code",
            "description": "The Python class code for the agent"
          },
          "answers": {
            "items": {
              "$ref": "#/components/schemas/AnswerItem"
            },
            "type": "array",
            "title": "Answers",
            "description": "List of answers submitted by the agent"
          }
        },
        "type": "object",
        "required": [
          "username",
          "agent_code",
          "answers"
        ],
        "title": "Submission"
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "type": "array",
            "title": "Location"
          },
          "msg": {
            "type": "string",
            "title": "Message"
          },
          "type": {
            "type": "string",
            "title": "Error Type"
          }
        },
        "type": "object",
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError"
      }
    }
  }
}